{
  "manifest_version": 3,
  "name": "URL Cleaner",
  "version": "1.0.0",
  "description": "Aggressively cleans the current page URL and copies it.",
  "permissions": [
    "activeTab",
    "clipboardWrite"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Clean URL"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}